# URL gốc của Worker tingting-api (KHÔNG kèm /api/bot/message)
WORKER_URL=https://tingting-api.example.workers.dev

# Chuỗi bí mật dùng chung với Worker (wrangler secret put BOT_SERVICE_SECRET)
BOT_SERVICE_SECRET=

# ID thread group chat Messenger (lấy từ URL messenger.com/t/<THREAD_ID>)
# Nhiều group chat: dùng THREAD_IDS="id1,id2" (mỗi thread một tab — server RAM thấp chỉ nên 2-3)
THREAD_ID=
#THREAD_IDS=

# Tên bot để bắt @mention trong chat (so khớp không phân biệt hoa thường/dấu)
BOT_NAME=TingTing

# Đường dẫn file cookie đăng nhập (tạo bằng: python save_login.py)
STORAGE_STATE=storage_state.json

# Chạy browser ẩn (true) hay hiện cửa sổ (false, để debug)
HEADLESS=true

# Chu kỳ đọc tin nhắn mới (giây)
POLL_SECONDS=4

# Restart browser định kỳ chống memory creep (giờ)
RESTART_HOURS=8

# Rover: tab tuần tra tự phát hiện group chat ngoài THREAD_IDS qua sidebar (RAM +1 tab cố định)
ROVER_ENABLED=true
# Bao lâu rover ghé một thread khác (giây, round-robin)
ROVER_INTERVAL_SECONDS=15
# Tối đa bao nhiêu thread sidebar được tuần tra
ROVER_MAX_THREADS=10

# Giờ ngủ hằng ngày (giờ máy chủ): bot tắt browser hẳn, giống người thật. Rỗng = chạy 24/7
QUIET_HOURS=02:00-04:00

# FastAPI bind (để 127.0.0.1 — không expose ra ngoài)
API_HOST=127.0.0.1
API_PORT=8090
